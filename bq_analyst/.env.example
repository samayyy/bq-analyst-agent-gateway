# Copy this file to bq_analyst/.env and fill in your values.
# `adk deploy agent_engine` consumes GOOGLE_CLOUD_PROJECT / GOOGLE_CLOUD_LOCATION
# as deploy defaults and ships every OTHER variable as a runtime env var.

GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
GOOGLE_CLOUD_LOCATION=YOUR_REGION          # e.g. asia-south1 (must support Agent Engine)

# Project whose BigQuery datasets the agent analyzes (also the billing project
# for its queries). Usually the same as GOOGLE_CLOUD_PROJECT.
BQ_PROJECT_ID=YOUR_PROJECT_ID

MODEL_NAME=gemini-3.1-flash-lite

# Agent Identity access tokens are certificate-bound; ADK's MCP transport (raw
# httpx) cannot present the mTLS binding yet (google/adk-python#5361), so bound
# tokens 401 at the managed MCP server. This documented opt-out makes the
# metadata server mint regular unbound tokens. Remove once #5361 is fixed.
GOOGLE_API_PREVENT_AGENT_TOKEN_SHARING_FOR_GCP_SERVICES=false

# Do NOT set GOOGLE_API_USE_CLIENT_CERTIFICATE=false on gateway-bound
# deployments: the agent->gateway leg IS the client-cert mTLS channel. With
# certs disabled the runtime dials plain hostnames and gets "Network is
# unreachable" (gateway-bound containers have no direct egress). Register the
# *.mtls.googleapis.com hostname permutations in the Agent Registry instead.
